# ─── Tether WDK ──────────────────────────────────────────────────────────────
# WDK mnemonic for generating agent wallets (leave empty for demo mode)
WDK_MNEMONIC=
# Network: ethereum, arbitrum, polygon, base (default: arbitrum)
WDK_NETWORK=arbitrum
# RPC URLs for WDK transactions
WDK_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/demo
# USDT contract address on target network (set after deploying MockUSDT or use real USDT)
USDT_CONTRACT=
# XAUT contract address (optional — for gold-backed asset support)
XAUT_CONTRACT=

# ─── Ports ────────────────────────────────────────────────────────────────────
PORT_SENTIMENT=4001
PORT_SENTIMENT2=4006
PORT_POLYMARKET=4002
PORT_DEFI=4003
PORT_NEWS=4004
PORT_WHALE=4005
PORT_AGENT=5000

# ─── Service Config ──────────────────────────────────────────────────────────
# CoinGecko is free (used by DeFi scanner and risk monitor)
# CryptoPanic API token (free at https://cryptopanic.com/developers/api/)
CRYPTOPANIC_TOKEN=

# Base Mainnet RPC for on-chain analysis
BASE_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# CORS
CORS_ORIGINS=*

# ─── LLM — Groq (free, fast) ────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_THRESHOLD=50

# ─── Autopilot ───────────────────────────────────────────────────────────────
AUTOPILOT_INTERVAL_MS=300000
AUTOPILOT_MIN_INTERVAL_MS=300000
AUTOPILOT_MAX_INTERVAL_MS=900000
AUTOPILOT_TOPICS=USDT lending,yield farming,DeFi alpha,credit scoring,tipping

# ─── Lending Config ──────────────────────────────────────────────────────────
# Aave pool address for yield scanning
AAVE_POOL_ADDRESS=
# Compound cToken address
COMPOUND_CTOKEN_ADDRESS=
# Minimum APY threshold to trigger yield alerts (basis points, e.g. 500 = 5%)
MIN_YIELD_THRESHOLD_BPS=300

# ─── Tipping Config ─────────────────────────────────────────────────────────
# Rumble API key (optional — uses mock data in demo mode)
RUMBLE_API_KEY=
# Default tip amount in USDT
DEFAULT_TIP_USDT=1.00
# Creator address for tipping (leave empty to use hunter wallet)
CREATOR_ADDRESS=
# Community pool address for aggregated tipping
TIPPING_POOL_ADDRESS=

# ─── Contract Addresses ────────────────────────────────────────────────────
# Deploy with `forge script` in foundry-deploy/, then set these addresses
LENDING_POOL_ADDRESS=
YIELD_VAULT_ADDRESS=

# ─── Bridge Config ──────────────────────────────────────────────────────────
# Default destination chain for USDT0 bridge (polygon, ethereum, base)
DEFAULT_BRIDGE_CHAIN=polygon

# ─── OpenClaw ───────────────────────────────────────────────────────────────
# Reasoning mode: embedded (uses Groq LLM), disabled
OPENCLAW_MODE=embedded
